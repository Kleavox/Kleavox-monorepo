{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "zarkiv-portfolio",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-05",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": "../../apps/portfolio/dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": ["/health"],
  },
  "observability": {
    "enabled": true,
  },
}
