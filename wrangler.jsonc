// wrangler.jsonc

{
  "name": "deauport",
  "compatibility_date": "2026-05-16",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@astrojs/cloudflare/entrypoints/server",

  "workers_dev": true,
  "preview_urls": false,

  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },

  "observability": {
    "enabled": true
  }
}
