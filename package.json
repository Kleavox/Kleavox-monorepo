{
  "name": "kleavox",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "compression:build": "pnpm --filter @kleavox/compression build",
    "compression:test": "pnpm --filter @kleavox/compression test",
    "agent:test": "go -C services/agent test ./...",
    "agent:build": "go -C services/agent build ./cmd/agent",
    "deploy:render": "node tooling/deploy/dist/cli.js render",
    "health:check": "node tooling/health/check.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm agent:test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.92.0"
  }
}
