{
  "name": "kleavox",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "compression:build": "pnpm --filter @kleavox/compression build",
    "compression:test": "pnpm --filter @kleavox/compression test",
    "rust:fmt": "cargo fmt --all --check",
    "rust:test": "cargo test --workspace --locked",
    "agent:test": "go -C services/agent test ./...",
    "agent:vet": "go -C services/agent vet ./...",
    "agent:build": "go -C services/agent build -buildvcs=false -o ../../bin/kleavox-agent ./cmd/agent",
    "agent:deadcode": "node tooling/lint/go-deadcode.mjs",
    "native:check": "pnpm rust:fmt && pnpm rust:test && pnpm agent:test && pnpm agent:vet && pnpm agent:build && pnpm agent:deadcode",
    "deploy:render": "node tooling/deploy/dist/cli.js render",
    "e2e": "pnpm --filter @kleavox/topology build && pnpm --filter @kleavox/e2e e2e",
    "health:check": "pnpm --filter @kleavox/topology build && node tooling/health/check.mjs",
    "admin:promote": "pnpm --filter @kleavox/topology build && node tooling/deploy/promote-admin.mjs",
    "check": "pnpm format:check && turbo run lint typecheck test build && pnpm native:check && pnpm knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "knip": "^6.16.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
