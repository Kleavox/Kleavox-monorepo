generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UptimeCheck {
  id           String       @id @default(cuid())
  name         String       @unique
  targetUrl    String       @unique
  intervalSec  Int          @default(60)
  enabled      Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  logs         UptimeLog[]

  @@index([enabled])
  @@index([targetUrl])
}

model UptimeLog {
  id         String     @id @default(cuid())
  checkId    String
  status     Int?
  latencyMs  Int?
  error      String?
  createdAt  DateTime    @default(now())

  check      UptimeCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([checkId, createdAt])
  @@index([status])
}

model ShortLink {
  id         String   @id @default(cuid())
  slug       String   @unique
  targetUrl  String   @unique
  enabled    Boolean  @default(true)
  hits       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
  @@index([slug])
}