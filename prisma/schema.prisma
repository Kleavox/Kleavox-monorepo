// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  
  files     File[]
}

model File {
  id        String    @id @default(cuid())
  key       String    @unique
  name      String
  type      String
  size      BigInt
  downloads Int       @default(0)
  
  expiresAt DateTime?
  
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([key])
  @@index([userId])
}