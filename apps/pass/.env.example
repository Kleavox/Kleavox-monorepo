# Production: real Turnstile site key (pair with `wrangler secret put TURNSTILE_SECRET_KEY` on the pass worker).
# Dev builds fall back to Cloudflare's public always-pass test key automatically.
VITE_TURNSTILE_SITE_KEY=
VITE_ROOT_ORIGIN=https://example.com
VITE_LINK_ORIGIN=https://link.example.com
VITE_PULSE_ORIGIN=https://pulse.example.com
