---
import { getPublicOrigin } from "@kleavox/config";
import "../styles/global.css";

const rootOrigin = import.meta.env.PUBLIC_ROOT_ORIGIN ?? "https://example.com";
const rootHost = new URL(rootOrigin).host;

const products = [
  { name: "Link", href: getPublicOrigin(rootOrigin, "link") },
  { name: "Pass", href: getPublicOrigin(rootOrigin, "pass") },
  { name: "Pulse", href: getPublicOrigin(rootOrigin, "pulse") },
  { name: "Port", href: getPublicOrigin(rootOrigin, "port") },
];
const [link, pass, pulse, port] = products;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Kleavox is a focused ecosystem for routes, temporary files, identity, and infrastructure monitoring."
    />
    <meta name="theme-color" content="#070810" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="Kleavox | Focused systems" />
    <meta
      property="og:description"
      content="Routes, temporary files, identity, and infrastructure monitoring under one deliberate system."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={rootOrigin} />
    <link rel="canonical" href={rootOrigin} />
    <title>Kleavox | Focused systems</title>
  </head>
  <body>
    <header class="hdr">
      <div class="shell hdr-inner">
        <a class="wm" href="/" aria-label="Kleavox home">Kleav<b>ox</b></a>
        <div class="account" data-account>
          <a class="btn-nav" href={pass.href} data-signin>Sign in</a>
          <div class="account-menu" data-account-menu hidden>
            <button
              type="button"
              class="account-trigger"
              data-account-trigger
              aria-expanded="false"
            >
              <span data-account-name></span>
            </button>
            <div class="account-dropdown" data-account-dropdown hidden>
              <button type="button" data-logout>Sign out</button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main>
      <section class="hero shell">
        <div class="hero-copy">
          <p class="kicker">KLEAVOX / SYSTEM</p>
          <h1>One<br />system.</h1>
          <p class="hero-lede">
            Public routes, shared identity, and infrastructure signals — all under one deliberate, edge-native platform.
          </p>
          <div class="hero-acts">
            <a class="btn-p" href={pass.href}>Open Pass <span aria-hidden="true">→</span></a>
          </div>
          <div class="route-sample" aria-hidden="true">
            <strong>{rootHost}</strong>
            <span>/launch</span>
            <i></i>
          </div>
        </div>

        <div class="mosaic" aria-label="Kleavox products">
          <a class="mc mc1" href={link.href} aria-label="Open Kleavox Link">
            <div class="mc-in">
              <span class="mc-label">KLEAVOX / LINK</span>
              <strong>One address for links.</strong>
              <div class="mc-deco mc-deco-link" aria-hidden="true">
                <span></span><span></span><span></span>
                <div><b></b><b></b><b></b><b></b></div>
              </div>
              <div class="mc-bar"></div>
            </div>
            <span class="mc-tag">Link /</span>
          </a>
          <a class="mc mc2" href={pass.href} aria-label="Open Kleavox Pass">
            <div class="mc-in">
              <span class="mc-label">KLEAVOX / PASS</span>
              <strong>One account.</strong>
              <div class="mc-deco mc-deco-pass" aria-hidden="true">
                <div class="orb"><i></i><i></i></div>
              </div>
              <div class="mc-bar"></div>
            </div>
            <span class="mc-tag">Pass /</span>
          </a>
          <a class="mc mc3" href={port.href} aria-label="Open Kleavox Port">
            <div class="mc-in">
              <span class="mc-label">KLEAVOX / PORT</span>
              <strong>Selected work.</strong>
              <div class="mc-deco mc-deco-port" aria-hidden="true">
                <i></i><i></i><i></i><i></i>
              </div>
              <div class="mc-bar"></div>
            </div>
            <span class="mc-tag">Port /</span>
          </a>
          <a
            class="mc mc4"
            href={pulse.href}
            aria-label="Open Kleavox Pulse"
            data-pulse-only
            hidden
          >
            <div class="mc-in">
              <span class="mc-label">KLEAVOX / PULSE</span>
              <strong>Watch every host.</strong>
              <div class="mc-deco mc-deco-pulse" aria-hidden="true">
                <i style="height:38%"></i><i style="height:62%"></i>
                <i style="height:48%"></i><i style="height:82%"></i>
                <i style="height:55%"></i><i style="height:70%"></i>
              </div>
              <div class="mc-bar"></div>
            </div>
            <span class="mc-tag">Pulse /</span>
          </a>
        </div>
      </section>
    </main>

    <footer class="ftr">
      <div class="shell ftr-inner">
        <span class="ftr-wm">Kleav<b>ox</b></span>
        <div class="ftr-links">
          <a href={link.href}>Link</a>
          <a href={pass.href}>Pass</a>
          <a href={pulse.href} data-pulse-only hidden>Pulse</a>
          <a href={port.href}>Port</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
        <span class="ftr-copy">&copy; {new Date().getFullYear()} Kleavox</span>
      </div>
    </footer>

    <script>
      import { firstName } from "@kleavox/core";

      const account = document.querySelector<HTMLElement>("[data-account]");
      const signIn = document.querySelector<HTMLElement>("[data-signin]");
      const menu = document.querySelector<HTMLElement>("[data-account-menu]");
      const trigger = document.querySelector<HTMLButtonElement>(
        "[data-account-trigger]",
      );
      const dropdown = document.querySelector<HTMLElement>(
        "[data-account-dropdown]",
      );
      const name = document.querySelector<HTMLElement>("[data-account-name]");
      const logout = document.querySelector<HTMLButtonElement>("[data-logout]");

      const closeMenu = () => {
        dropdown?.setAttribute("hidden", "");
        trigger?.setAttribute("aria-expanded", "false");
      };

      trigger?.addEventListener("click", (event) => {
        event.stopPropagation();
        const open = trigger.getAttribute("aria-expanded") === "true";
        if (open) {
          closeMenu();
        } else {
          dropdown?.removeAttribute("hidden");
          trigger.setAttribute("aria-expanded", "true");
        }
      });

      dropdown?.addEventListener("click", (event) => event.stopPropagation());
      window.addEventListener("click", closeMenu);

      logout?.addEventListener("click", async () => {
        try {
          await fetch("/api/logout", { method: "POST", credentials: "include" });
        } finally {
          window.location.reload();
        }
      });

      fetch("/api/session", { credentials: "include" })
        .then((response) => (response.ok ? response.json() : { authenticated: false }))
        .then((data: { authenticated: boolean; identity?: { name?: string; email?: string; role?: string } }) => {
          if (!data.authenticated || !data.identity) return;
          if (name) {
            name.textContent = firstName(data.identity.name, data.identity.email);
          }
          signIn?.setAttribute("hidden", "");
          menu?.removeAttribute("hidden");
          account?.classList.add("is-authenticated");
          if (data.identity.role === "ADMIN") {
            document
              .querySelectorAll("[data-pulse-only]")
              .forEach((element) => element.removeAttribute("hidden"));
          }
        })
        .catch(() => {});
    </script>
  </body>
</html>
