---
import "../styles/global.css";

const products = [
  {
    name: "Link",
    number: "01",
    href: "https://link.zarkiv.com",
    statement: "Short links and files.",
    detail: "Create routes, track visits, and send temporary files.",
    capabilities: ["Custom slugs", "Analytics", "Temporary files"],
  },
  {
    name: "Pass",
    number: "02",
    href: "https://pass.zarkiv.com",
    statement: "One account.",
    detail: "Email, Google, and GitHub login for Zarkiv.",
    capabilities: ["Shared session", "OAuth", "Account recovery"],
  },
  {
    name: "Pulse",
    number: "03",
    href: "https://pulse.zarkiv.com",
    statement: "Watch every host.",
    detail: "Metrics and checks from a small Go agent.",
    capabilities: ["Host metrics", "Health checks", "Incident history"],
  },
  {
    name: "Port",
    number: "04",
    href: "https://port.zarkiv.com",
    statement: "Selected work.",
    detail: "Hardware, software, and infrastructure by Hafidh Musyafa.",
    capabilities: ["Embedded", "Software", "Infrastructure"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Zarkiv is a focused ecosystem for routes, temporary files, identity, and infrastructure monitoring."
    />
    <meta name="theme-color" content="#0b0d0c" />
    <meta property="og:title" content="Zarkiv | Focused systems" />
    <meta
      property="og:description"
      content="Routes, temporary files, identity, and infrastructure monitoring under one deliberate system."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://zarkiv.com" />
    <link rel="canonical" href="https://zarkiv.com" />
    <title>Zarkiv | Focused systems</title>
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="Zarkiv home">Zarkiv</a>
      <nav aria-label="Primary navigation">
        <a href="#products">Products</a>
        <a href="#system">System</a>
        <a class="nav-action" href="https://pass.zarkiv.com">Sign in</a>
      </nav>
    </header>

    <main>
      <section class="hero shell" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow">ZARKIV / SYSTEM</p>
          <h1 id="hero-title">Useful tools.<br />One system.</h1>
          <p class="hero-lede">Links, files, identity, and server monitoring.</p>
          <a class="primary-action" href="#products">
            Open products
            <span aria-hidden="true">↘</span>
          </a>
        </div>

        <div class="product-mosaic" aria-label="Zarkiv product previews">
          {products.map((product, index) => (
            <a
              class={`mosaic-item mosaic-item-${index + 1}`}
              href={product.href}
              aria-label={`Open Zarkiv ${product.name}`}
            >
              <div class="mosaic-preview">
                <small>ZARKIV / {product.name.toUpperCase()}</small>
                <strong>{product.statement}</strong>
                <i></i>
              </div>
              <span>{product.name} ↗</span>
            </a>
          ))}
        </div>
      </section>

      <section class="statement-band" aria-label="Zarkiv purpose">
        <p>Small tools. Clear jobs.</p>
      </section>

      <section id="products" class="products shell" aria-labelledby="products-title">
        <div class="section-heading">
          <p class="section-label">PRODUCTS / 04</p>
          <h2 id="products-title">Pick a tool.</h2>
        </div>

        <div class="product-index">
          {products.map((product) => (
            <article class="product-row reveal">
              <div class="product-id">
                <span>{product.number}</span>
                <strong>{product.name}</strong>
              </div>
              <div class="product-copy">
                <h3>{product.statement}</h3>
                <p>{product.detail}</p>
              </div>
              <ul aria-label={`${product.name} capabilities`}>
                {product.capabilities.map((capability) => <li>{capability}</li>)}
              </ul>
              <a class="product-link" href={product.href} aria-label={`Open Zarkiv ${product.name}`}>
                Open {product.name}
                <span aria-hidden="true">↗</span>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section id="system" class="system shell" aria-labelledby="system-title">
        <div class="system-title">
          <p class="section-label">ARCHITECTURE</p>
          <h2 id="system-title">One domain.<br />Separate workers.</h2>
        </div>

        <div class="architecture" aria-label="Zarkiv architecture">
          <div class="architecture-domain">
            <span>Public edge</span>
            <strong>zarkiv.com</strong>
            <p>Website and short-link resolution.</p>
          </div>
          <div class="architecture-route" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="architecture-products">
            {products.map((product) => (
              <a href={product.href}>
                <strong>{product.name}</strong>
                <span>{product.name.toLowerCase()}.zarkiv.com</span>
              </a>
            ))}
          </div>
        </div>

        <div class="principles">
          <article>
            <span>01</span>
            <h3>Independent</h3>
            <p>Each product deploys and stores data separately.</p>
          </article>
          <article>
            <span>02</span>
            <h3>One login</h3>
            <p>Pass shares identity across products.</p>
          </article>
          <article>
            <span>03</span>
            <h3>Edge first</h3>
            <p>TypeScript Workers and a Go host agent.</p>
          </article>
        </div>
      </section>

      <section class="closing shell" aria-labelledby="closing-title">
        <p class="section-label">START</p>
        <h2 id="closing-title">Create an account.<br />Use every tool.</h2>
        <div class="closing-actions">
          <a class="primary-action" href="https://pass.zarkiv.com">
            Create your account
            <span aria-hidden="true">↗</span>
          </a>
          <a class="text-action" href="https://link.zarkiv.com">Open Link</a>
        </div>
      </section>
    </main>

    <footer class="site-footer shell">
      <a class="wordmark" href="/">Zarkiv</a>
      <p>Tools by Hafidh Musyafa.</p>
      <div>
        <a href="https://link.zarkiv.com">Link</a>
        <a href="https://pass.zarkiv.com">Pass</a>
        <a href="https://pulse.zarkiv.com">Pulse</a>
        <a href="https://port.zarkiv.com">Port</a>
      </div>
      <span>© {new Date().getFullYear()} Zarkiv</span>
    </footer>

    <script>
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reducedMotion && "IntersectionObserver" in window) {
        document.documentElement.classList.add("motion-ready");
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));
      }
    </script>
  </body>
</html>
