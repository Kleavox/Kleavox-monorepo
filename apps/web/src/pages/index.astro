---
import "../styles/global.css";

const rootOrigin = import.meta.env.PUBLIC_ROOT_ORIGIN ?? "https://example.com";
const rootHost = new URL(rootOrigin).host;
const productOrigin = (subdomain: string) =>
  new URL(`https://${subdomain}.${rootHost}`).toString().replace(/\/$/u, "");

const products = [
  {
    name: "Link",
    domain: "link",
    number: "01",
    href: productOrigin("link"),
    statement: "One address for links and files.",
    detail: "Route a destination or send the file itself from one workspace.",
    capabilities: ["Custom slugs", "Analytics", "Expiring files"],
  },
  {
    name: "Pass",
    domain: "pass",
    number: "02",
    href: productOrigin("pass"),
    statement: "One account.",
    detail: "Email, Google, and GitHub login for Kleavox.",
    capabilities: ["Shared session", "OAuth", "Account recovery"],
  },
  {
    name: "Pulse",
    domain: "pulse",
    number: "03",
    href: productOrigin("pulse"),
    statement: "Watch every host.",
    detail: "Metrics and checks from a small Go agent.",
    capabilities: ["Host metrics", "Health checks", "Incident history"],
  },
  {
    name: "Port",
    domain: "port",
    number: "04",
    href: productOrigin("port"),
    statement: "Selected work.",
    detail: "Selected hardware, software, and infrastructure work.",
    capabilities: ["Embedded", "Software", "Infrastructure"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Kleavox is a focused ecosystem for routes, temporary files, identity, and infrastructure monitoring."
    />
    <meta name="theme-color" content="#0b0d0c" />
    <meta property="og:title" content="Kleavox | Focused systems" />
    <meta
      property="og:description"
      content="Routes, temporary files, identity, and infrastructure monitoring under one deliberate system."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={rootOrigin} />
    <link rel="canonical" href={rootOrigin} />
    <title>Kleavox | Focused systems</title>
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="Kleavox home">Kleavox</a>
      <nav aria-label="Primary navigation">
        <a href="#products">Products</a>
        <a href="#system">System</a>
        <a class="nav-action" href={productOrigin("pass")}>Sign in</a>
      </nav>
    </header>

    <main>
      <section class="hero shell" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow">KLEAVOX / SYSTEM</p>
          <h1 id="hero-title">Useful tools.<br />One system.</h1>
          <p class="hero-lede">Public routes, shared identity, and infrastructure signals.</p>
          <a class="primary-action" href="#products">
            Open products
            <span aria-hidden="true">/</span>
          </a>
          <div class="route-sample" aria-label="Example Kleavox public address">
            <span>{rootHost}/</span>
            <strong>your-slug</strong>
            <i></i>
          </div>
        </div>

        <div class="product-mosaic" aria-label="Kleavox product previews">
          {products.map((product, index) => (
            <a
              class={`mosaic-item mosaic-item-${index + 1}`}
              href={product.href}
              aria-label={`Open Kleavox ${product.name}`}
            >
              <div class="mosaic-preview">
                <small>KLEAVOX / {product.name.toUpperCase()}</small>
                <strong>{product.statement}</strong>
                <i></i>
              </div>
              <span>{product.name} /</span>
            </a>
          ))}
        </div>
      </section>

      <section class="statement-band" aria-label="Kleavox purpose">
        <p>One address. Four focused systems.</p>
      </section>

      <section id="products" class="products shell" aria-labelledby="products-title">
        <div class="section-heading">
          <p class="section-label">PRODUCTS / 04</p>
          <h2 id="products-title">Pick a tool.</h2>
        </div>

        <div class="product-index">
          {products.map((product) => (
            <article class="product-row reveal">
              <div class="product-id">
                <span>{product.number}</span>
                <strong>{product.name}</strong>
              </div>
              <div class="product-copy">
                <h3>{product.statement}</h3>
                <p>{product.detail}</p>
              </div>
              <ul aria-label={`${product.name} capabilities`}>
                {product.capabilities.map((capability) => <li>{capability}</li>)}
              </ul>
              <a class="product-link" href={product.href} aria-label={`Open Kleavox ${product.name}`}>
                Open {product.name}
                <span aria-hidden="true">/</span>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section id="system" class="system shell" aria-labelledby="system-title">
        <div class="system-title">
          <p class="section-label">ARCHITECTURE</p>
          <h2 id="system-title">One domain.<br />Separate workers.</h2>
        </div>

        <div class="architecture" aria-label="Kleavox architecture">
          <div class="architecture-domain">
            <span>Public edge</span>
            <strong>{rootHost}</strong>
            <p>Website, short routes, and temporary file delivery.</p>
          </div>
          <div class="architecture-route" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="architecture-products">
            {products.map((product) => (
              <a href={product.href}>
                <strong>{product.name}</strong>
                <span>{product.domain}.{rootHost}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="principles">
          <article>
            <span>01</span>
            <h3>Independent</h3>
            <p>Each product deploys and stores data separately.</p>
          </article>
          <article>
            <span>02</span>
            <h3>One login</h3>
            <p>Pass shares identity across products.</p>
          </article>
          <article>
            <span>03</span>
            <h3>Edge first</h3>
            <p>TypeScript Workers and a Go host agent.</p>
          </article>
        </div>
      </section>

      <section class="closing shell" aria-labelledby="closing-title">
        <p class="section-label">START</p>
        <h2 id="closing-title">Create an account.<br />Use every tool.</h2>
        <div class="closing-actions">
          <a class="primary-action" href={productOrigin("pass")}>
            Create your account
            <span aria-hidden="true">/</span>
          </a>
          <a class="text-action" href={productOrigin("link")}>Open Link</a>
        </div>
      </section>
    </main>

    <footer class="site-footer shell">
      <a class="wordmark" href="/">Kleavox</a>
      <p>Independent tools for public routes and infrastructure.</p>
      <div>
        <a href={productOrigin("link")}>Link</a>
        <a href={productOrigin("pass")}>Pass</a>
        <a href={productOrigin("pulse")}>Pulse</a>
        <a href={productOrigin("port")}>Port</a>
      </div>
      <span>(c) {new Date().getFullYear()} Kleavox</span>
    </footer>

    <script>
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reducedMotion && "IntersectionObserver" in window) {
        document.documentElement.classList.add("motion-ready");
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));
      }
    </script>
  </body>
</html>
