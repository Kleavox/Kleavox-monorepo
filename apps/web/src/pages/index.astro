---
import { getPublicOrigin } from "@kleavox/config";
import "../styles/global.css";

const rootOrigin = import.meta.env.PUBLIC_ROOT_ORIGIN ?? "https://example.com";
const rootHost = new URL(rootOrigin).host;

const products = [
  {
    name: "Link",
    domain: "link",
    href: getPublicOrigin(rootOrigin, "link"),
    statement: "One address for links and files.",
  },
  {
    name: "Pass",
    domain: "pass",
    href: getPublicOrigin(rootOrigin, "pass"),
    statement: "One account.",
  },
  {
    name: "Pulse",
    domain: "pulse",
    href: getPublicOrigin(rootOrigin, "pulse"),
    statement: "Watch every host.",
  },
  {
    name: "Port",
    domain: "port",
    href: getPublicOrigin(rootOrigin, "port"),
    statement: "Selected work.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Kleavox is a focused ecosystem for routes, temporary files, identity, and infrastructure monitoring."
    />
    <meta name="theme-color" content="#070908" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="Kleavox | Focused systems" />
    <meta
      property="og:description"
      content="Routes, temporary files, identity, and infrastructure monitoring under one deliberate system."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={rootOrigin} />
    <link rel="canonical" href={rootOrigin} />
    <title>Kleavox | Focused systems</title>
  </head>
  <body>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="wordmark" href="/" aria-label="Kleavox home">Kleavox</a>
        <nav aria-label="Primary navigation">
          <a class="nav-action" href={getPublicOrigin(rootOrigin, "pass")}>Sign in</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero shell" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow">KLEAVOX / SYSTEM</p>
          <h1 id="hero-title">One system.</h1>
          <p class="hero-lede">Public routes, shared identity, and infrastructure signals.</p>
          <a class="primary-action" href={getPublicOrigin(rootOrigin, "pass")}>
            Open Pass
            <span aria-hidden="true">/</span>
          </a>
        </div>

        <div class="product-mosaic" aria-label="Kleavox product previews">
          {products.map((product, index) => (
            <a
              class={`mosaic-item mosaic-item-${index + 1}`}
              href={product.href}
              aria-label={`Open Kleavox ${product.name}`}
            >
              <div class="mosaic-preview">
                <small>KLEAVOX / {product.name.toUpperCase()}</small>
                <strong>{product.statement}</strong>
                {index === 0 && (
                  <div class="mosaic-deco" aria-hidden="true">
                    <div class="md-rows">
                      <span></span><span></span><span></span>
                    </div>
                    <div class="md-dots">
                      <b></b><b></b><b></b><b></b><b></b>
                    </div>
                  </div>
                )}
                {index === 1 && (
                  <div class="mosaic-deco mosaic-deco-pass" aria-hidden="true">
                    <div class="md-orbit"><i></i><i></i></div>
                  </div>
                )}
                {index === 2 && (
                  <div class="mosaic-deco mosaic-deco-pulse" aria-hidden="true">
                    <div class="md-bars">
                      <i style="--h:38%"></i><i style="--h:65%"></i>
                      <i style="--h:48%"></i><i style="--h:85%"></i>
                      <i style="--h:58%"></i><i style="--h:72%"></i>
                    </div>
                  </div>
                )}
                {index === 3 && (
                  <div class="mosaic-deco mosaic-deco-port" aria-hidden="true">
                    <div class="md-grid">
                      <i></i><i></i><i></i><i></i>
                    </div>
                  </div>
                )}
                <i></i>
              </div>
              <span>{product.name} /</span>
            </a>
          ))}
        </div>
      </section>

      <section class="statement-band" aria-labelledby="system-title">
        <div>
          <p class="section-label" style="color: var(--accent-ink)">ARCHITECTURE</p>
          <h2 id="system-title">One domain.<br />Separate workers.</h2>
          <p class="system-desc" style="color: var(--accent-ink)">
            Kleavox is designed as a unified monorepo. While it appears as a single platform, each product is powered by strictly isolated Cloudflare Workers. This ensures extreme performance at the edge while maintaining deep integration through shared core configurations and identity protocols.
          </p>
        </div>
      </section>

      <section id="system" class="system shell">
        <div class="architecture" aria-label="Kleavox architecture">
          <div class="architecture-domain">
            <span>Public edge</span>
            <strong>{rootHost}</strong>
            <p>Website, short routes, and temporary file delivery.</p>
          </div>
          <div class="architecture-route" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="architecture-products">
            {products.map((product) => (
              <a href={product.href}>
                <strong>{product.name}</strong>
                <span>{product.domain}.{rootHost}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer shell">
      <a class="wordmark" href="/">Kleavox</a>
      <p>Independent tools for public routes and infrastructure.</p>
      <div>
        <a href={getPublicOrigin(rootOrigin, "link")}>Link</a>
        <a href={getPublicOrigin(rootOrigin, "pass")}>Pass</a>
        <a href={getPublicOrigin(rootOrigin, "pulse")}>Pulse</a>
        <a href={getPublicOrigin(rootOrigin, "port")}>Port</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
      <span>(c) {new Date().getFullYear()} Kleavox</span>
    </footer>
  </body>
</html>
