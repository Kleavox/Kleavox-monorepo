---
import "../styles/global.css";
import "../styles/legal.css";

const rootOrigin = import.meta.env.PUBLIC_ROOT_ORIGIN ?? "https://example.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Terms governing access to and use of Kleavox services."
    />
    <link rel="canonical" href={`${rootOrigin}/terms`} />
    <title>Terms of Service | Kleavox</title>
  </head>
  <body>
    <header class="legal-header">
      <a class="wordmark" href="/">Kleavox</a>
      <nav aria-label="Policy navigation">
        <a href="/privacy">Privacy</a>
        <a href="/">Home</a>
      </nav>
    </header>

    <main class="legal-main">
      <p class="section-label">POLICY / TERMS</p>
      <h1>Use the system responsibly.</h1>
      <p class="legal-intro">
        These terms govern access to Kleavox and its identity, link, temporary
        file, monitoring, and portfolio services. Effective June 7, 2026.
      </p>

      <section class="legal-section">
        <h2>Acceptable use</h2>
        <p>
          Do not use Kleavox to distribute malware, facilitate fraud, violate
          privacy or intellectual-property rights, evade access controls, abuse
          infrastructure, or conduct unlawful activity.
        </p>
      </section>

      <section class="legal-section">
        <h2>Your account and content</h2>
        <p>
          You are responsible for activity performed through your account and
          for content you submit. Keep credentials secure and ensure you have
          the rights and permissions required to share any destination, file,
          message, or monitoring target.
        </p>
      </section>

      <section class="legal-section">
        <h2>Temporary services</h2>
        <p>
          Links, files, metrics, and related records may expire, be deleted,
          become unavailable, or be limited to protect users and infrastructure.
          Kleavox is not a permanent backup or archival service.
        </p>
      </section>

      <section class="legal-section">
        <h2>Availability and changes</h2>
        <p>
          Services are provided on an as-available basis. Features, limits, and
          integrations may change. Access may be suspended or terminated when
          necessary to address abuse, security risk, legal requirements, or
          operational constraints.
        </p>
      </section>

      <section class="legal-section">
        <h2>Disclaimers and liability</h2>
        <p>
          To the extent permitted by applicable law, Kleavox is provided
          without warranties and is not liable for indirect, incidental,
          special, consequential, or data-loss damages arising from use of the
          service.
        </p>
      </section>

      <section class="legal-section">
        <h2>Privacy and contact</h2>
        <p>
          Data handling is described in the Privacy Policy. Questions about
          these terms can be submitted through the Kleavox Port contact form.
        </p>
      </section>
    </main>

    <footer class="legal-footer">
      <span>(c) {new Date().getFullYear()} Kleavox</span>
      <a href="/">Return home</a>
    </footer>
  </body>
</html>
