---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Not found | Kleavox</title>
  </head>
  <body>
    <main class="not-found shell">
      <a class="wordmark" href="/">Kleavox</a>
      <div>
        <p class="section-label">404</p>
        <h1>Nothing lives at this address.</h1>
        <p>
          The route is neither a Kleavox page nor an active short link.
        </p>
        <a class="primary-action" href="/">
          Return home
          <span aria-hidden="true">/</span>
        </a>
      </div>
    </main>
  </body>
</html>

<style>
  .not-found {
    min-height: 100dvh;
    padding-block: 2rem clamp(4rem, 10vw, 8rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .not-found div {
    max-width: 900px;
  }

  .not-found h1 {
    max-width: 10ch;
  }

  .not-found div > p:not(.section-label) {
    max-width: 40ch;
    margin: 2rem 0;
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }
</style>
