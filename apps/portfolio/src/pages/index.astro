---
import { getPublicOrigin } from "@kleavox/config";
import "../styles/global.css";

const rootOrigin = import.meta.env.PUBLIC_ROOT_ORIGIN ?? "https://example.com";
const portfolioOrigin = getPublicOrigin(rootOrigin, "port");
const portfolioName = "Hafidh Musyafa";
const portfolioLocation = "Semarang, Indonesia";
const githubUrl = "https://github.com/Kleavox";
const linkedinUrl = "https://www.linkedin.com/in/hmus122/";
const initials = portfolioName
  .split(/\s+/u)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0]?.toUpperCase())
  .join("");

const disciplines = [
  ["embedded", "PCB design, ESP32 firmware, sensor integration"],
  ["software", "TypeScript, Go, Python, C and C++"],
  ["interfaces", "Astro, React, Flutter, accessible product UI"],
  ["systems", "Cloudflare, Linux, Docker, VPS operations"],
];

const projects = [
  {
    index: "01",
    name: "Kleavox",
    status: "active",
    type: "edge ecosystem",
    description:
      "A Cloudflare-first ecosystem for identity, short routes, temporary file delivery, and infrastructure monitoring.",
    stack: "TypeScript / Workers / D1 / R2 / Go",
    href: "https://github.com/Kleavox/kleavox-monorepo",
  },
  {
    index: "02",
    name: "Embedded Platform",
    status: "assembled",
    type: "embedded hardware",
    description:
      "A modular controller platform built around a custom PCB, with swappable sensor boards and a compact firmware interface.",
    stack: "KiCad / ESP32 / IMU / Rust",
    href: "https://github.com/Kleavox/DeltaT32",
  },
  {
    index: "03",
    name: "Operations Interface",
    status: "shipped",
    type: "mobile system",
    description:
      "A mobile operations surface combining live status, announcements, and location-aware workflows.",
    stack: "Flutter / Dart / REST / Geolocation",
    href: "https://github.com/doswall/doswall-mobile",
  },
];

const timeline = [
  ["NOW", "Systems practice", "Hardware, software, and infrastructure"],
  ["RECENT", "Product engineering", "Interfaces backed by observable systems"],
  ["ONGOING", "Embedded research", "Sensors, controllers, and edge workloads"],
];

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={`Portfolio of ${portfolioName}, spanning embedded systems, infrastructure, and product interfaces.`}
    />
    <meta name="theme-color" content="#080b10" />
    <meta property="og:title" content={`${portfolioName} | Systems and interfaces`} />
    <meta
      property="og:description"
      content="Work spanning sensor hardware, edge infrastructure, and deliberate product interfaces."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={portfolioOrigin} />
    <link rel="canonical" href={portfolioOrigin} />
    <title>{portfolioName} | Systems and interfaces</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="port-nav">
      <a class="port-mark" href="/" aria-label="Portfolio home">
        <span>{initials || "PO"}</span>
        <strong>PORT / 26</strong>
      </a>
      <nav aria-label="Portfolio navigation">
        <a href="#work">Work</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <a class="nav-system" href={rootOrigin}>Kleavox / system</a>
      </nav>
    </header>

    <main id="main">
      <section class="port-hero">
        <div class="hero-grid" aria-hidden="true"></div>
        <div class="hero-copy">
          <p class="mono-label">{portfolioLocation.toUpperCase()} / AVAILABLE</p>
          <h1>Hardware intuition.<br /><em>Software reach.</em></h1>
          <p class="hero-intro">
            I&apos;m Hafidh Musyafa, a computer engineering student building
            across the entire signal path: from sensor boards and host agents to
            edge services and the interfaces people actually touch.
          </p>
          <div class="hero-actions">
            <a class="signal-action" href="#work">Selected work <span>01</span></a>
            <a class="quiet-action" href={githubUrl}>GitHub / source</a>
          </div>
        </div>

        <div class="instrument-stack" aria-label="Live engineering instruments">
          <article class="instrument instrument-primary">
            <header>
              <span><i></i> BMI270 / orientation</span>
              <b id="orientation-readout">X +0.00 / Y +0.00</b>
            </header>
            <div class="axis-stage" id="axis-stage">
              <span class="axis axis-x">X</span>
              <span class="axis axis-y">Y</span>
              <span class="axis axis-z">Z</span>
              <div class="board-model"></div>
            </div>
            <footer>I2C 0x68 <span>pointer reactive</span></footer>
          </article>
          <article class="instrument signal-panel">
            <header>
              <span><i></i> system / pulse</span>
              <b>64 BPM</b>
            </header>
            <svg viewBox="0 0 600 96" role="img" aria-label="Animated pulse signal">
              <path
                d="M0 64H70L82 61L92 66L104 62L119 64L135 58L148 12L162 82L176 51L194 64H270L282 61L292 66L304 62L319 64L335 58L348 12L362 82L376 51L394 64H470L482 61L492 66L504 62L519 64L535 58L548 12L562 82L576 51L600 64"
              ></path>
            </svg>
            <footer>250 HZ <span>signal nominal</span></footer>
          </article>
        </div>
      </section>

      <section class="manifesto">
        <p class="mono-label">OPERATING PRINCIPLE</p>
        <p>
          Build the physical thing first, instrument it honestly, and let the
          interface explain what the system already makes visible.
        </p>
      </section>

      <section id="work" class="port-section work-section">
        <header class="section-heading">
          <p class="mono-label">01 / SELECTED WORK</p>
          <h2>Systems with a pulse.</h2>
        </header>
        <div class="project-list">
          {
            projects.map((project) => (
              <a class="project-row reveal" href={project.href}>
                <div class="project-id">
                  <span>{project.index}</span>
                  <i data-status={project.status}></i>
                </div>
                <div class="project-name">
                  <h3>{project.name}</h3>
                  <p>{project.type}</p>
                </div>
                <p class="project-description">{project.description}</p>
                <div class="project-meta">
                  <span>{project.stack}</span>
                  <strong>{project.status} / open</strong>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <section id="about" class="port-section about-section">
        <header class="section-heading">
          <p class="mono-label">02 / RANGE</p>
          <h2>One stack, many scales.</h2>
        </header>
        <div class="about-grid">
          <div class="discipline-list">
            {
              disciplines.map(([name, detail], index) => (
                <article class="reveal">
                  <span>0{index + 1}</span>
                  <h3>{name}</h3>
                  <p>{detail}</p>
                </article>
              ))
            }
          </div>
          <div class="timeline">
            <p class="mono-label">TIMELINE / SIGNAL LOG</p>
            <ol>
              {
                timeline.map(([date, title, note]) => (
                  <li>
                    <time>{date}</time>
                    <div>
                      <strong>{title}</strong>
                      <span>{note}</span>
                    </div>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
      </section>

      <section id="contact" class="contact-section">
        <header class="section-heading">
          <p class="mono-label">03 / CONTACT</p>
          <h2>Let&apos;s build something.</h2>
        </header>
        <div class="contact-grid">
          <div class="contact-copy">
            <p>Embedded systems, IoT, web products, or infrastructure.</p>
            <span>Send a message through Kleavox Port.</span>
          </div>
          <form id="contact-form" class="contact-form">
            <label>
              <span>Name</span>
              <input name="name" maxlength="100" required />
            </label>
            <label>
              <span>Email</span>
              <input name="email" type="email" required />
            </label>
            <label>
              <span>Message</span>
              <textarea name="message" minlength="10" maxlength="2000" required></textarea>
            </label>
            <div
              class="cf-turnstile"
              data-sitekey={turnstileSiteKey}
              data-theme="dark"
            ></div>
            <button class="signal-action" type="submit">Send message <span>/</span></button>
            <p id="contact-status" role="status"></p>
          </form>
        </div>
      </section>
    </main>

    <footer class="port-footer">
      <span>{portfolioName} / {new Date().getFullYear()}</span>
      <span>{portfolioLocation}</span>
      <div>
        <a href={githubUrl}>GitHub</a>
        {linkedinUrl && <a href={linkedinUrl}>LinkedIn</a>}
      </div>
    </footer>

    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script>
      const stage = document.querySelector<HTMLElement>("#axis-stage");
      const model = document.querySelector<HTMLElement>(".board-model");
      const readout = document.querySelector<HTMLElement>("#orientation-readout");
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (stage && model && readout && !reduced) {
        stage.addEventListener("pointermove", (event: PointerEvent) => {
          const bounds = stage.getBoundingClientRect();
          const x = (event.clientX - bounds.left) / bounds.width - 0.5;
          const y = (event.clientY - bounds.top) / bounds.height - 0.5;
          model.style.transform =
            `rotateX(${(-y * 24).toFixed(2)}deg) rotateY(${(x * 34).toFixed(2)}deg)`;
          readout.textContent =
            `X ${(x * 2).toFixed(2)} / Y ${(-y * 2).toFixed(2)}`;
        });
        stage.addEventListener("pointerleave", () => {
          model.style.transform = "rotateX(58deg) rotateZ(-28deg)";
          readout.textContent = "X +0.00 / Y +0.00";
        });
      }

      if (!reduced && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.14 },
        );
        document.querySelectorAll(".reveal").forEach((item) => observer.observe(item));
      }

      const contactForm = document.querySelector<HTMLFormElement>("#contact-form");
      const contactStatus = document.querySelector<HTMLElement>("#contact-status");
      contactForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const submit = contactForm.querySelector<HTMLButtonElement>("button");
        const data = new FormData(contactForm);
        const turnstileToken = data.get("cf-turnstile-response");
        if (!turnstileToken) {
          if (contactStatus) contactStatus.textContent = "Complete the verification.";
          return;
        }
        if (submit) submit.disabled = true;
        if (contactStatus) contactStatus.textContent = "Sending...";
        try {
          const response = await fetch("/api/contact", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              name: data.get("name"),
              email: data.get("email"),
              message: data.get("message"),
              turnstileToken,
            }),
          });
          const result = await response.json() as { error?: string };
          if (!response.ok) throw new Error(result.error || "Message failed.");
          contactForm.reset();
          if (contactStatus) contactStatus.textContent = "Message sent.";
        } catch (error) {
          if (contactStatus) {
            contactStatus.textContent =
              error instanceof Error ? error.message : "Message failed.";
          }
        } finally {
          if (submit) submit.disabled = false;
        }
      });
    </script>
  </body>
</html>
