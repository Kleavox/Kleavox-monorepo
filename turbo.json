{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_*", "PUBLIC_*"],
      "outputs": ["dist/**", ".astro/**", "pkg/**"]
    },
    "@kleavox/crypto#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!src/wasm-base64.ts", "../../crates/crypto/src/**", "../../crates/crypto/Cargo.toml", "../../crates/crypto/Cargo.lock"],
      "outputs": ["dist/**", "pkg/**", "src/wasm-base64.ts"]
    },
    "@kleavox/compression#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../../crates/compression/src/**", "../../crates/compression/Cargo.toml", "../../crates/compression/Cargo.lock"],
      "outputs": ["dist/**", "pkg/**", "src/wasm-base64.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
