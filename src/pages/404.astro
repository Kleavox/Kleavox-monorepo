---
// src/pages/404.astro

import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
---

<Layout title="404 — Not Found">
  <Nav />
  <main
    class="min-h-screen flex flex-col items-center justify-center px-6"
    style="padding-top: 56px;"
  >
    <p class="font-mono text-xs mb-6" style="color: var(--text-dim); letter-spacing: 0.1em;">
      404 / not found
    </p>

    <h1
      class="leading-none mb-5 text-center"
      style="font-size: clamp(3rem, 8vw, 5.5rem); font-weight: 700; letter-spacing: -0.03em; color: var(--text);"
    >
      Lost in<br />
      <span style="color: var(--accent);">the signal.</span>
    </h1>

    <div style="height: 1px; width: 40px; background: var(--border-mid); margin-bottom: 1.25rem;"></div>

    <p class="text-sm mb-10 text-center" style="color: var(--text-muted); max-width: 320px; line-height: 1.65;">
      This page does not exist. Maybe it was moved, deleted, or never existed.
    </p>

    <a
      href="/"
      class="font-mono text-sm px-5 py-2.5"
      style="background: var(--accent); color: var(--bg); border-radius: 4px; font-weight: 600; letter-spacing: 0.02em;"
    >
      back to home
    </a>
  </main>
</Layout>
