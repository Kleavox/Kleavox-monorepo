---
const projects = [
  {
    name: 'DeauBit',
    tag: 'web · active',
    status: 'active',
    category: 'Web · CF Workers',
    description:
      'Self-hosted URL shortener with click analytics, QR code generation, password-protected links, self-destruct expiry, and abuse reporting. Full-stack on Cloudflare: Next.js 16 frontend, Hono.js backend on CF Workers, D1 (SQLite) for storage, KV for sessions, and Resend for email.',
    stack: ['Next.js 16', 'Hono.js', 'CF Workers', 'CF D1', 'TypeScript', 'Tailwind v4', 'Resend', 'Turnstile'],
    repo: 'https://github.com/VorDeau/deaubit',
    note: 'Still actively updated',
  },
  {
    name: 'Doswall Mobile',
    tag: 'mobile · 2024 to 2025',
    status: 'done',
    category: 'Mobile · Flutter',
    description:
      'Lecturer wallboard app displaying real-time attendance status and campus announcements on TV screens. Originally built in Kotlin (DoGoes), fully rebuilt in Flutter/Dart for cross-platform support with REST API integration and real-time geolocation.',
    stack: ['Flutter', 'Dart', 'REST API', 'Geolocation', 'Kotlin (prior)'],
    repo: 'https://github.com/doswall/doswall-mobile',
    repoAlt: { label: 'original (kotlin)', href: 'https://github.com/VorDeau/DoGoes' },
    note: 'DoGoes → doswall-mobile migration',
  },
  {
    name: 'DeltaT32',
    tag: 'hardware · Q3 2025',
    status: 'done',
    category: 'PCB · Embedded',
    description:
      'Modular hardware design built in KiCad 8, centered on the ESP32-C3 Mini-1. Comprises a main ESP unit and two hot-swappable sensor daughter boards: BMI270/BMI160 (IMU) and MPU9250 (9-axis). Intended for wearable and general-purpose embedded applications, with esp-rs (Rust) firmware compatibility in mind. Assembly completed Q3 2025.',
    stack: ['KiCad 8', 'ESP32-C3', 'BMI270', 'MPU9250', 'esp-rs'],
    repo: 'https://github.com/VorDeau/DeltaT32',
    note: null,
  },
]

const statusStyle: Record<string, { color: string; label: string }> = {
  active: { color: 'var(--green)',    label: 'active' },
  done:   { color: 'var(--text-dim)', label: 'done'   },
}
---

<section id="projects" class="py-28" style="border-top: 1px solid var(--border);">
  <div class="max-w-5xl mx-auto px-6">

    <p
      data-reveal="fade"
      class="font-mono text-xs mb-12"
      style="color: var(--text-dim); letter-spacing: 0.1em;"
    >
      03 / projects
    </p>

    <div class="space-y-px" style="border: 1px solid var(--border); border-radius: 8px; overflow: hidden;">
      {projects.map((p, idx) => {
        const s = statusStyle[p.status]
        return (
          <article
            data-reveal
            style={`--reveal-delay: ${0.05 + idx * 0.1}s; background: var(--bg-surface);`}
            class="p-6 transition-colors duration-150"
            data-project
          >
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-3">
              <div class="flex items-center gap-3 flex-wrap">
                <h3 class="font-semibold text-base" style="color: var(--text);">{p.name}</h3>
                <span class="flex items-center gap-1.5">
                  <span
                    style={`width: 5px; height: 5px; border-radius: 50%; background: ${s.color}; display: inline-block;`}
                  ></span>
                  <span class="font-mono text-xs" style={`color: ${s.color};`}>{s.label}</span>
                </span>
                {p.note && (
                  <span class="font-mono text-xs" style="color: var(--text-dim);">
                    · {p.note}
                  </span>
                )}
              </div>
              <div class="flex items-center gap-3 flex-shrink-0">
                <span class="font-mono text-xs" style="color: var(--text-dim);">{p.tag}</span>
                <span
                  class="font-mono text-xs px-2 py-0.5"
                  style="border: 1px solid var(--border); color: var(--text-muted); border-radius: 3px;"
                >
                  {p.category}
                </span>
              </div>
            </div>

            <p class="text-sm mb-4" style="color: var(--text-muted); line-height: 1.65; max-width: 680px;">
              {p.description}
            </p>

            <div class="flex items-center justify-between flex-wrap gap-3">
              <ul class="flex flex-wrap gap-2">
                {p.stack.map(t => (
                  <li
                    class="font-mono text-xs px-2 py-1"
                    style="background: var(--bg-elevated); color: var(--text-muted); border-radius: 3px;"
                  >
                    {t}
                  </li>
                ))}
              </ul>
              <div class="flex items-center gap-4">
                {'repoAlt' in p && p.repoAlt && (
                  <a
                    href={p.repoAlt.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-mono text-xs transition-colors"
                    style="color: var(--text-dim);"
                  >
                    {p.repoAlt.label} ↗
                  </a>
                )}
                <a
                  href={p.repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-xs transition-colors"
                  style="color: var(--text-dim);"
                >
                  repo ↗
                </a>
              </div>
            </div>
          </article>
        )
      })}
    </div>

    <div class="mt-8 text-center">
      <a
        href="https://github.com/VorDeau"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs"
        style="color: var(--text-dim);"
      >
        more on github ↗
      </a>
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('[data-project]').forEach(el => {
    el.addEventListener('mouseenter', () => {
      (el as HTMLElement).style.background = 'var(--bg-elevated)'
    })
    el.addEventListener('mouseleave', () => {
      (el as HTMLElement).style.background = 'var(--bg-surface)'
    })
  })
</script>
