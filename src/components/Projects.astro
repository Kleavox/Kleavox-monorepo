---
const projects = [
  {
    id: 'sicermat',
    name: 'SICermat',
    tag: 'capstone · 2024—',
    status: 'active',
    category: 'Embedded · Mobile',
    description:
      'Wearable health and motion monitoring system. ESP32-C3 mainboard with detachable BMI270 (IMU) and MAX30102 (PPG) sensor modules, on-device activity recognition via Edge Impulse, and a Flutter dashboard app for real-time data visualization.',
    stack: ['ESP32-C3', 'BMI270', 'MAX30102', 'Edge Impulse', 'Flutter', 'BLE 5.0'],
    repo: 'https://github.com/VorDeau/DeltaT32',
  },
  {
    id: 'deltat32',
    name: 'DeltaT32',
    tag: 'pcb · 2025',
    status: 'done',
    category: 'Hardware · PCB',
    description:
      'Modular PCB system designed in KiCad 8. Comprises an ESP32-C3 Mini-1 mainboard and two hot-swappable sensor daughter boards (BMI270 and MPU9250). Designed for wearable applications with Rust (esp-rs) firmware compatibility in mind.',
    stack: ['KiCad 8', 'ESP32-C3', 'BMI270', 'MPU9250', 'esp-rs'],
    repo: 'https://github.com/VorDeau/DeltaT32',
  },
  {
    id: 'rnn-lstm-har',
    name: 'RNN LSTM — Human Activity Recognition',
    tag: 'ml · 2024',
    status: 'done',
    category: 'ML · Data',
    description:
      'Two-layer LSTM architecture for classifying human activities from IMU sensor data. 4-class output with dropout regularization. 461,124 trainable parameters. Built with TensorFlow/Keras.',
    stack: ['TensorFlow', 'Keras', 'LSTM', 'Python', 'NumPy'],
    repo: null,
  },
  {
    id: 'doswall',
    name: 'Doswall App Rebuild',
    tag: 'mobile · 2024',
    status: 'done',
    category: 'Mobile',
    description:
      'Cross-platform rebuild of a geolocation-based app, migrating from native Kotlin (Dogoes) to Flutter/Dart. Integrated REST API and real-time geolocation services for broader device support.',
    stack: ['Flutter', 'Dart', 'REST API', 'Geolocation'],
    repo: null,
  },
  {
    id: 'esp32s3-monitor',
    name: 'ESP32-S3 Biometric Monitor',
    tag: 'hardware · 2023',
    status: 'done',
    category: 'Embedded · PCB',
    description:
      'Compact PCB integrating ESP32-S3, MPU6050 (6-axis IMU), and MAX30102 (heart rate / SpO₂) for real-time wearable biometric monitoring. Designed for health and activity tracking research applications.',
    stack: ['ESP32-S3', 'MPU6050', 'MAX30102', 'KiCad'],
    repo: null,
  },
]

const statusStyle: Record<string, { color: string; label: string }> = {
  active: { color: 'var(--green)',  label: 'active' },
  done:   { color: 'var(--text-dim)', label: 'done'   },
  wip:    { color: 'var(--amber)',  label: 'wip'    },
}
---

<section id="projects" class="py-28" style="border-top: 1px solid var(--border);">
  <div class="max-w-5xl mx-auto px-6">

    <p class="font-mono text-xs mb-12" style="color: var(--text-dim); letter-spacing: 0.1em;">
      03 / projects
    </p>

    <div class="space-y-px" style="border: 1px solid var(--border); border-radius: 8px; overflow: hidden;">
      {projects.map(p => {
        const s = statusStyle[p.status]
        return (
          <article
            class="group p-6 transition-colors duration-150"
            style="background: var(--bg-surface);"
            data-project
          >
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-3">
              <div class="flex items-center gap-3 flex-wrap">
                <h3 class="font-semibold text-base" style="color: var(--text);">{p.name}</h3>
                <span
                  class="flex items-center gap-1.5"
                >
                  <span
                    style={`width: 5px; height: 5px; border-radius: 50%; background: ${s.color}; display: inline-block;`}
                  ></span>
                  <span class="font-mono text-xs" style={`color: ${s.color};`}>{s.label}</span>
                </span>
              </div>
              <div class="flex items-center gap-3 flex-shrink-0">
                <span class="font-mono text-xs" style="color: var(--text-dim);">{p.tag}</span>
                <span
                  class="font-mono text-xs px-2 py-0.5"
                  style="border: 1px solid var(--border); color: var(--text-muted); border-radius: 3px;"
                >
                  {p.category}
                </span>
              </div>
            </div>

            <p class="text-sm mb-4" style="color: var(--text-muted); line-height: 1.65; max-width: 660px;">
              {p.description}
            </p>

            <div class="flex items-center justify-between flex-wrap gap-3">
              <ul class="flex flex-wrap gap-2">
                {p.stack.map(t => (
                  <li
                    class="font-mono text-xs px-2 py-1"
                    style="background: var(--bg-elevated); color: var(--text-muted); border-radius: 3px;"
                  >
                    {t}
                  </li>
                ))}
              </ul>
              {p.repo && (
                <a
                  href={p.repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-xs transition-colors"
                  style="color: var(--text-dim);"
                >
                  repo ↗
                </a>
              )}
            </div>
          </article>
        )
      })}
    </div>

    <div class="mt-8 text-center">
      <a
        href="https://github.com/J58C"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs"
        style="color: var(--text-dim);"
      >
        more on github ↗
      </a>
    </div>

  </div>
</section>

<script>
  // Hover highlight for project rows
  document.querySelectorAll('[data-project]').forEach(el => {
    el.addEventListener('mouseenter', () => {
      (el as HTMLElement).style.background = 'var(--bg-elevated)'
    })
    el.addEventListener('mouseleave', () => {
      (el as HTMLElement).style.background = 'var(--bg-surface)'
    })
  })
</script>
