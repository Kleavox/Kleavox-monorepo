---
const rows = [
  {
    label: 'embedded',
    color: 'var(--accent)',
    items: ['PCB Design', 'Microcontroller Programming', 'Embedded Firmware'],
  },
  {
    label: 'languages',
    color: 'var(--amber)',
    items: ['C / C++', 'Python', 'Java'],
  },
  {
    label: 'web',
    color: 'var(--green)',
    items: ['Next.js', 'Astro', 'Hono.js', 'React', 'Tailwind CSS'],
  },
  {
    label: 'mobile',
    color: '#c084fc',
    items: ['Flutter', 'Kotlin / Jetpack Compose'],
  },
  {
    label: 'infra',
    color: 'var(--text-muted)',
    items: ['Cloudflare', 'Docker', 'Linux', 'VPS'],
  },
]
---

<section id="skills" class="py-24" style="border-top: 1px solid var(--border);">
  <div class="max-w-5xl mx-auto px-6">

    <p
      class="font-mono text-xs mb-10"
      data-reveal="fade"
      style="color: var(--text-dim); letter-spacing: 0.1em;"
    >
      02 / skills
    </p>

    <div
      data-reveal="fade"
      style="--reveal-delay: 0.1s; border: 1px solid var(--border); border-radius: 8px; overflow: hidden;"
    >
      {rows.map((row, i) => (
        <div
          data-reveal
          style={`--reveal-delay: ${0.1 + i * 0.08}s; display: flex; align-items: baseline; gap: 2rem; padding: 1rem 1.5rem; background: var(--bg-surface); ${i > 0 ? 'border-top: 1px solid var(--border);' : ''}`}
          class="flex-col sm:flex-row"
        >
          <span
            class="font-mono text-xs flex-shrink-0"
            style={`color: ${row.color}; width: 72px; letter-spacing: 0.06em;`}
          >
            {row.label}
          </span>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            {row.items.join('  ·  ')}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
