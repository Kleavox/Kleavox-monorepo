---
// src/components/Footer.astro

---

<footer
  class="py-10"
  style="border-top: 1px solid var(--border);"
>
  <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="font-mono text-xs" style="color: var(--text-dim);">
      Hafidh Musyafa · <span id="footer-year"></span>
    </span>
    <div class="flex items-center gap-6">
      <a
        href="https://github.com/VorDeau"
        target="_blank" rel="noopener noreferrer"
        class="font-mono text-xs transition-colors"
        style="color: var(--text-dim);"
      >
        github
      </a>
      <a
        href="https://www.linkedin.com/in/hmus122/"
        target="_blank" rel="noopener noreferrer"
        class="font-mono text-xs transition-colors"
        style="color: var(--text-dim);"
      >
        linkedin
      </a>
    </div>
    <span class="font-mono text-xs" style="color: var(--text-dim);">
      Astro · React · Tailwind · CF Workers
    </span>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year')
  if (el) el.textContent = String(new Date().getFullYear())
</script>
