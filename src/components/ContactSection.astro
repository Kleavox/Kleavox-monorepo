---
import Contact from './Contact.tsx'
---

<section id="contact" class="py-28" style="border-top: 1px solid var(--border);">
  <div class="max-w-5xl mx-auto px-6">

    <p class="font-mono text-xs mb-12" style="color: var(--text-dim); letter-spacing: 0.1em;">
      04 / contact
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: copy -->
      <div>
        <h2
          class="mb-6"
          style="font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; color: var(--text);"
        >
          Let's build<br />
          <span style="color: var(--accent);">something.</span>
        </h2>

        <p class="mb-8" style="color: var(--text-muted); font-size: 0.925rem; line-height: 1.75; max-width: 380px;">
          Interested in collaborating on embedded systems, IoT projects, web apps,
          or just want to talk hardware and code — reach out.
        </p>

        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs" style="color: var(--text-dim); min-width: 72px;">email</span>
            <a
              href="mailto:hello@deauport.id"
              class="font-mono text-xs transition-colors"
              style="color: var(--text-muted);"
            >
              hello@deauport.id
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs" style="color: var(--text-dim); min-width: 72px;">response</span>
            <span class="font-mono text-xs" style="color: var(--text-muted);">&lt; 24h on weekdays</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs" style="color: var(--text-dim); min-width: 72px;">location</span>
            <span class="font-mono text-xs" style="color: var(--text-muted);">Semarang, Indonesia</span>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <Contact client:load />
      </div>

    </div>
  </div>
</section>
