{
  "name": "@kleavox/crypto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wasm": "./pkg/kleavox_crypto_bg.wasm",
    "./pkg/*": "./pkg/*"
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir ../../packages/crypto/pkg --out-name kleavox_crypto --release ../../crates/crypto --locked && tsc -p tsconfig.json --checkers 1"
  },
  "devDependencies": {
    "@kleavox/typescript": "workspace:*",
    "typescript": "catalog:"
  }
}
