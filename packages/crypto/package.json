{
  "name": "@kleavox/crypto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wasm": "./pkg/kleavox_crypto_bg.wasm"
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir ../../packages/crypto/pkg --out-name kleavox_crypto --release ../../crates/crypto --locked && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "cargo test --manifest-path ../../crates/crypto/Cargo.toml --locked",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
