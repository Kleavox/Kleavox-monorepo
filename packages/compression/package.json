{
  "name": "@kleavox/compression",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir ../../packages/compression/pkg --out-name kleavox_compression --release ../../crates/compression --locked && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "cargo test --manifest-path ../../crates/compression/Cargo.toml --locked",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
